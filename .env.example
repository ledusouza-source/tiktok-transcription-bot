# Variáveis de Ambiente para o Bot de Transcrição TikTok/Instagram
# Copie este arquivo para .env e preencha com suas credenciais

# Token do Bot Telegram (obtenha via @BotFather)
BOT_TOKEN=seu_bot_token_aqui

# Chave de API da OpenAI (obtenha em https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-proj-sua-chave-aqui

# ID do Chat/Grupo do Telegram para enviar resultados (número, pode ser negativo)
TARGET_CHAT_ID=seu_chat_id_aqui
